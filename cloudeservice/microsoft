<!doctype html>
<html lang="en">
<head>
  <link rel="canonical" href="https://nasrutechnologies.com/cloudservice/microsoft.com" />

  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <title>Microsoft Cloud Solutions - Nasru Technologies</title>
  <meta name="description" content="Get Microsoft 365 Business Premium and Microsoft cloud solutions from Nasru Technologies. Business email, Teams, SharePoint, OneDrive, security, and device management for small and mid-sized businesses." />
  <link rel="icon" href="../../assets/img/logo.png?v=2" type="image/png">

  <style>
    :root {
      --nasru-blue: #0b5cff;
      --nasru-dark: #07111f;
      --nasru-navy: #0d1b2f;
      --nasru-light: #f5f8ff;
      --nasru-muted: #667085;
      --white: #ffffff;
      --border: rgba(15, 23, 42, 0.12);
      --shadow: 0 18px 45px rgba(7, 17, 31, 0.12);
      --green: #12b76a;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: Arial, Helvetica, sans-serif;
      color: var(--nasru-dark);
      background: var(--white);
      line-height: 1.6;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    .container {
      width: min(1180px, calc(100% - 40px));
      margin: 0 auto;
    }

    header {
      position: sticky;
      top: 0;
      z-index: 50;
      background: rgba(255, 255, 255, 0.92);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border);
    }

    .nav {
      min-height: 82px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 12px;
      font-weight: 800;
      letter-spacing: -0.02em;
    }

    .brand img {
      width: 48px;
      height: 48px;
      object-fit: contain;
    }

    .brand span {
      font-size: 1.1rem;
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 26px;
      color: #344054;
      font-size: 0.95rem;
      font-weight: 600;
    }

    .nav-links a:hover {
      color: var(--nasru-blue);
    }

    .nav-cta {
      background: var(--nasru-blue);
      color: var(--white);
      padding: 11px 18px;
      border-radius: 999px;
      font-weight: 700;
      box-shadow: 0 12px 24px rgba(11, 92, 255, 0.24);
    }

    .hero {
      position: relative;
      overflow: hidden;
      background:
        radial-gradient(circle at 82% 18%, rgba(11, 92, 255, 0.18), transparent 30%),
        radial-gradient(circle at 10% 80%, rgba(18, 183, 106, 0.12), transparent 26%),
        linear-gradient(135deg, #f8fbff 0%, #ffffff 50%, #edf4ff 100%);
      padding: 92px 0 78px;
    }

    .breadcrumb {
      display: flex;
      gap: 8px;
      align-items: center;
      color: var(--nasru-muted);
      font-size: 0.92rem;
      margin-bottom: 22px;
      font-weight: 700;
    }

    .breadcrumb a {
      color: var(--nasru-blue);
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 1.05fr 0.95fr;
      gap: 56px;
      align-items: center;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 13px;
      border: 1px solid rgba(11, 92, 255, 0.2);
      background: rgba(11, 92, 255, 0.08);
      color: var(--nasru-blue);
      border-radius: 999px;
      font-size: 0.84rem;
      font-weight: 800;
      margin-bottom: 22px;
    }

    h1 {
      font-size: clamp(2.4rem, 5vw, 4.65rem);
      line-height: 1.03;
      letter-spacing: -0.055em;
      margin-bottom: 24px;
    }

    .hero p {
      font-size: 1.13rem;
      color: var(--nasru-muted);
      max-width: 650px;
      margin-bottom: 34px;
    }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
      align-items: center;
    }

    .btn-primary,
    .btn-secondary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 48px;
      padding: 13px 22px;
      border-radius: 999px;
      font-weight: 800;
      transition: 0.2s ease;
    }

    .btn-primary {
      background: var(--nasru-blue);
      color: var(--white);
      box-shadow: 0 14px 28px rgba(11, 92, 255, 0.25);
    }

    .btn-secondary {
      background: var(--white);
      color: var(--nasru-dark);
      border: 1px solid var(--border);
    }

    .btn-primary:hover,
    .btn-secondary:hover {
      transform: translateY(-2px);
    }

    .hero-card {
      background: rgba(255, 255, 255, 0.78);
      border: 1px solid rgba(255, 255, 255, 0.95);
      border-radius: 34px;
      box-shadow: var(--shadow);
      padding: 30px;
    }

    .logo-box {
      height: 110px;
      border-radius: 24px;
      border: 1px dashed rgba(11, 92, 255, 0.34);
      background: #ffffff;
      display: grid;
      place-items: center;
      text-align: center;
      color: var(--nasru-muted);
      font-weight: 800;
      margin-bottom: 22px;
    }

    .highlight-list {
      display: grid;
      gap: 12px;
    }

    .highlight-item {
      display: flex;
      gap: 12px;
      align-items: flex-start;
      padding: 15px;
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 20px;
    }

    .check {
      width: 24px;
      height: 24px;
      flex: 0 0 24px;
      display: grid;
      place-items: center;
      border-radius: 999px;
      background: rgba(18, 183, 106, 0.12);
      color: var(--green);
      font-weight: 900;
    }

    .highlight-item h3 {
      font-size: 1rem;
      margin-bottom: 2px;
    }

    .highlight-item p {
      font-size: 0.9rem;
      margin: 0;
      color: var(--nasru-muted);
    }

    section {
      padding: 82px 0;
    }

    .section-heading {
      text-align: center;
      max-width: 790px;
      margin: 0 auto 46px;
    }

    .section-heading h2 {
      font-size: clamp(2rem, 3.4vw, 3rem);
      line-height: 1.08;
      letter-spacing: -0.04em;
      margin-bottom: 16px;
    }

    .section-heading p {
      color: var(--nasru-muted);
      font-size: 1.05rem;
    }

    .product-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 22px;
    }

    .product-card {
      display: flex;
      flex-direction: column;
      min-height: 420px;
      padding: 28px;
      border: 1px solid var(--border);
      border-radius: 28px;
      background: var(--white);
      box-shadow: 0 10px 30px rgba(7, 17, 31, 0.06);
      transition: 0.24s ease;
    }

    .product-card.featured {
      border: 2px solid rgba(11, 92, 255, 0.35);
      box-shadow: var(--shadow);
    }

    .product-card:hover {
      transform: translateY(-6px);
      box-shadow: var(--shadow);
    }

    .tag {
      width: fit-content;
      padding: 6px 11px;
      border-radius: 999px;
      background: rgba(11, 92, 255, 0.08);
      color: var(--nasru-blue);
      font-size: 0.78rem;
      font-weight: 900;
      margin-bottom: 18px;
    }

    .product-card h3 {
      font-size: 1.35rem;
      letter-spacing: -0.02em;
      margin-bottom: 10px;
    }

    .product-card p {
      color: var(--nasru-muted);
      font-size: 0.96rem;
      margin-bottom: 20px;
    }

    .price {
      padding: 18px;
      border-radius: 20px;
      background: var(--nasru-light);
      margin-bottom: 20px;
    }

    .price strong {
      display: block;
      font-size: 1.55rem;
      letter-spacing: -0.03em;
    }

    .price span {
      color: var(--nasru-muted);
      font-size: 0.9rem;
    }

    .product-card ul {
      list-style: none;
      display: grid;
      gap: 9px;
      margin-bottom: 24px;
      color: #344054;
      font-size: 0.92rem;
    }

    .product-card li::before {
      content: "✓";
      color: var(--nasru-blue);
      font-weight: 900;
      margin-right: 8px;
    }

    .product-card .product-btn {
      margin-top: auto;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      padding: 12px 16px;
      border-radius: 999px;
      background: var(--nasru-dark);
      color: var(--white);
      font-weight: 800;
      transition: 0.2s ease;
    }

    .product-card .product-btn:hover {
      background: var(--nasru-blue);
    }

    .services-section {
      background: var(--nasru-light);
    }

    .services-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 18px;
    }

    .service-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 24px;
      padding: 24px;
      box-shadow: 0 10px 26px rgba(7, 17, 31, 0.05);
    }

    .service-card h3 {
      font-size: 1.08rem;
      margin-bottom: 8px;
    }

    .service-card p {
      color: var(--nasru-muted);
      font-size: 0.94rem;
    }

    .bundle {
      display: grid;
      grid-template-columns: 0.9fr 1.1fr;
      gap: 32px;
      align-items: center;
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 34px;
      padding: 34px;
      box-shadow: var(--shadow);
    }

    .bundle-visual {
      min-height: 330px;
      border-radius: 28px;
      background:
        radial-gradient(circle at 75% 20%, rgba(11, 92, 255, 0.24), transparent 28%),
        linear-gradient(135deg, #07111f, #0d1b2f);
      color: var(--white);
      display: grid;
      place-items: center;
      text-align: center;
      padding: 30px;
    }

    .bundle-visual h3 {
      font-size: 2rem;
      letter-spacing: -0.04em;
      line-height: 1.1;
    }

    .bundle-content h2 {
      font-size: clamp(1.9rem, 3vw, 2.8rem);
      line-height: 1.1;
      letter-spacing: -0.04em;
      margin-bottom: 14px;
    }

    .bundle-content p {
      color: var(--nasru-muted);
      margin-bottom: 22px;
    }

    .bundle-content ul {
      list-style: none;
      display: grid;
      gap: 10px;
      margin-bottom: 26px;
      color: #344054;
    }

    .bundle-content li::before {
      content: "✓";
      color: var(--green);
      font-weight: 900;
      margin-right: 8px;
    }

    .cta {
      background: linear-gradient(135deg, var(--nasru-dark), var(--nasru-navy));
      color: var(--white);
      border-radius: 36px;
      padding: 54px;
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 24px;
      align-items: center;
      box-shadow: var(--shadow);
    }

    .cta h2 {
      font-size: clamp(1.9rem, 3vw, 3rem);
      line-height: 1.1;
      letter-spacing: -0.04em;
      margin-bottom: 12px;
    }

    .cta p {
      color: rgba(255, 255, 255, 0.74);
      max-width: 680px;
    }

    .cta .btn-primary {
      background: var(--white);
      color: var(--nasru-dark);
      box-shadow: none;
      white-space: nowrap;
    }

    footer {
      padding: 34px 0;
      border-top: 1px solid var(--border);
      color: var(--nasru-muted);
      font-size: 0.92rem;
    }

    .footer-inner {
      display: flex;
      justify-content: space-between;
      gap: 20px;
      flex-wrap: wrap;
    }

    @media (max-width: 1080px) {
      .hero-grid,
      .bundle,
      .cta {
        grid-template-columns: 1fr;
      }

      .product-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .services-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 760px) {
      .nav {
        padding: 18px 0;
        align-items: flex-start;
      }

      .nav-links {
        display: none;
      }

      .hero {
        padding: 62px 0 54px;
      }

      .product-grid,
      .services-grid {
        grid-template-columns: 1fr;
      }

      .cta,
      .bundle {
        padding: 32px 24px;
      }
    }
  </style>
</head>
